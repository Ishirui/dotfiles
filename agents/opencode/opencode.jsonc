{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["anthropic", "openai", "google", "github-copilot"],
  "share": "disabled",
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
    },
    "webfetch": "ask",
    "doom_loop": "ask",
    "external_directory": "ask",
  },
  "plugin": [
    "~/dd/opencode-datadog/",
    "@plannotator/opencode",
    "@gotgenes/opencode-agent-identity",
    [
      "@knikolov/opencode-plugin-simple-memory",
      {
        "autoLoad": false,
        "autoSave": false,
      },
    ],
    "opencode-handoff",
    "superpowers@git+https://github.com/obra/superpowers.git",
    // Take some stuff from https://github.com/smartfrog/opencode-froggy/ but without using it wholesale
  ],
}
