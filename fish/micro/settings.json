{
  "autoindent": true,
  "autosave": 0,
  "backup": true,
  "colorscheme": "catppuccin-macchiato-transparent",
  "cursorline": true,
  "diffgutter": true,
  "encoding": "utf-8",
  "eofnewline": true,
  "fileformat": "unix",
  "hlsearch": true,
  "ignorecase": true,
  "incsearch": true,
  "infobar": true,
  "mouse": true,
  "ruler": true,
  "savehistory": true,
  "savecursor": false,
  "scrollmargin": 3,
  "scrollspeed": 2,
  "smartpaste": true,
  "softwrap": false,
  "splitbottom": true,
  "splitright": true,
  "statusline": true,
  "syntax": true,
  "tabsize": 4,
  "tabstospaces": true,
  "truecolor": "auto",
  "wordwrap": false
}
